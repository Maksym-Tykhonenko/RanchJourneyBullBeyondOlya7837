# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'RanchJourneyBullBeyond' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :new_arch_enabled => false,
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Keep third-party RN C++ pods compatible with newer Xcode releases.
    pods_to_relax = ['Yoga', 'fmt', 'RCT-Folly']
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = min_ios_version_supported
        build_config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO' if pods_to_relax.include?(target.name)
        build_config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17' if target.name == 'fmt'
      end

      next unless pods_to_relax.include?(target.name)

      target.source_build_phase.files.each do |build_file|
        next unless build_file.settings && build_file.settings['COMPILER_FLAGS']

        flags = build_file.settings['COMPILER_FLAGS'].split
        next unless flags.delete('-Werror')

        build_file.settings['COMPILER_FLAGS'] = flags.join(' ')
      end
    end

    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(
        "#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 1",
        "#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 0"
      )

      if patched != content
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
      end
    end
  end
end
